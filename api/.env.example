# Server
PORT=3000

# Admin dashboard & pool status auth (/api/debug/dashboard?key=... and /api/debug/pool?key=...)
API_KEY=change_me_to_a_strong_secret

# WebSocket CORS — set to your Cloudflare tunnel domain in production
# Local dev: http://localhost:3000
# Production: https://your-domain.com
ALLOWED_ORIGIN=http://localhost:3000

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# Session pool — auto-kill GUI apps after this duration (ms). Default: 20 min
SESSION_TIMEOUT_MS=1200000
